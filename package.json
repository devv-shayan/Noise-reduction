{
  "name": "noise-reduction-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "frontend:dev": "vite",
    "dev": "npm run tauri:dev",
    "frontend:build": "tsc && vite build",
    "build": "npm run tauri:build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && cargo check --manifest-path src-tauri/Cargo.toml",
    "engine:install": "uv sync --project engine",
    "engine:run": "uv run --project engine engine/run.py --port 8000",
    "engine:build": "uv run --project engine engine/build_sidecar.py",
    "tauri:dev": "npm run engine:build && tauri dev",
    "tauri:build": "npm run engine:build && tauri build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.4.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "tailwindcss": "^4.1.13",
    "typescript": "^5",
    "vite": "^6"
  }
}
